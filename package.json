{
  "name": "hsmission",
  "version": "1.1.0",
  "description": "Website for the Haitian Sensation Mission Nonprofit, designed to inform readers about challenges facing Haiti and collect donations via the Zeffy platform.",
  "homepage": "https://haitiansensationmission.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nick-poole/hsmission.git"
  },
  "author": "Nick Poole <napoole@protonmail.com>",
  "scripts": {
    "build": "sass src/scss/main.scss dist/css/main.output.css --style=compressed --no-source-map",
    "watch": "sass --watch src/scss/main.scss:dist/css/main.output.css --no-source-map",
    "dev": "npx http-server -p 8080 -c-1"
  },
  "devDependencies": {
    "sass": "^1.66.1"
  },
  "engines": {
    "node": ">=18"
  },
  "private": true
}
